<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- TOP BUTTON - Shows a toast message -->
    <Button
        android:id="@+id/btn_show_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SHOW TOAST"
        android:textColor="#FFFFFF"
        app:backgroundTint="#0027D4"/>

    <!-- CENTER AREA - Contains counter and greeting button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFC107"
        android:gravity="center"
        android:orientation="vertical">

        <!-- COUNTER DISPLAY - Shows the number -->
        <TextView
            android:id="@+id/txt_counter_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="120sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"/>

        <!-- GREETING BUTTON - Shows a hello message -->
        <Button
            android:id="@+id/btn_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Say hhiiiiii!"
            app:backgroundTint="#9E9E9E"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

    <!-- BOTTOM BUTTON - Increases the counter -->
    <Button
        android:id="@+id/btn_increase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INCREASE up up"
        android:textColor="#FFFFFF"
        app:backgroundTint="#0027D4"/>

</LinearLayout>